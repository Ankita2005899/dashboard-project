@app.route("/search-products")
def search_products():
    query = request.args.get("q", "").strip()
    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)

    # SQL for all products if query empty, else filtered
    if not query:
        sql = """
        SELECT 'card' AS category_table, id, name, category,
               COALESCE(searched_count,0) AS todays_searched_count,
               last_searched_time
        FROM card
        UNION ALL
        SELECT 'study_material', id, name, category,
               COALESCE(searched_count,0), last_searched_time
        FROM study_material
        UNION ALL
        SELECT 'food_items', id, name, category,
               COALESCE(searched_count,0), last_searched_time
        FROM food_items
        """
        cursor.execute(sql)
        results = cursor.fetchall()
    else:
        like_pattern = f"%{query}%"
        sql = """
        SELECT 'card' AS category_table, id, name, category,
               COALESCE(searched_count,0) AS todays_searched_count,
               last_searched_time
        FROM card WHERE name LIKE %s
        UNION ALL
        SELECT 'study_material', id, name, category,
               COALESCE(searched_count,0), last_searched_time
        FROM study_material WHERE name LIKE %s
        UNION ALL
        SELECT 'food_items', id, name, category,
               COALESCE(searched_count,0), last_searched_time
        FROM food_items WHERE name LIKE %s
        """
        cursor.execute(sql, (like_pattern, like_pattern, like_pattern))
        results = cursor.fetchall()

        # Increment searched_count and update last_searched_time
        for item in results:
            update_sql = f"""
                UPDATE {item['category_table']}
                SET searched_count = searched_count + 1,
                    last_searched_time = NOW()
                WHERE id = %s
            """
            cursor.execute(update_sql, (item['id'],))
        conn.commit()

        # Re-fetch updated results
        cursor.execute(sql, (like_pattern, like_pattern, like_pattern))
        results = cursor.fetchall()

    cursor.close()
    conn.close()
    return jsonify(results)

